{
  "discord": {
    "webhook_url": "https://discord.com/api/webhooks/DEINE/WEBHOOK_URL",
    "bot_token": "",
    "channel_id": "",
    "bot_name": "Server Chat",
    "language": "en",
    "discord_to_game": false,
    "poll_interval": 5
  },
  "plugin": {
    "debug_mode": true,
    "log_file": "PalworldDiscordPlugin.log",
