  },
  "events": {
    "chat": true,
    "join": true,
    "leave": true,
    "death": true
  },
  "bridge": {
    "enabled": true,
    "incoming_file": "PalDiscordBridge_in.txt",
    "outgoing_file": "PalDiscordBridge_out.txt"
  }
}
